#!/bin/bash

# Check if PYFILE environment variable is set
if [ -z "$PYFILE" ]; then
    echo "Error: PYFILE environment variable not set."
    exit 1
fi

# Extract the file name without extension
filename=$(basename -- "$PYFILE")
filename_noext="${filename%.*}"

# Compile the Python script
echo "Compiling $PYFILE ..."
python3 -m py_compile "$PYFILE"

# Check if compilation was successful
if [ $? -eq 0 ]; then
    # Get the cache tag for the current Python version
    cache_tag=$(python3 -c 'import sys; print(sys.implementation.cache_tag)')

    # Determine the compiled file path
    compiled_filename="__pycache__/$filename_noext.$cache_tag.pyc"

    # Rename the compiled file
    mv "$compiled_filename" "$filename_noext.pyc"

    # Remove the __pycache__ directory
    rm -r "__pycache__"

    echo "Compilation successful. Compiled file: $filename_noext.pyc"
else
    echo "Compilation failed."
fi

