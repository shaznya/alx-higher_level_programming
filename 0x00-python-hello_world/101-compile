#!/usr/bin/python3
import os
import py_compile

def compile_python_script():
    # Get the Python file name from the environment variable
    pyfile = os.environ.get('PYFILE')

    if not pyfile:
        print("Error: PYFILE environment variable is not set.")
        return

    # Ensure the file exists
    if not os.path.exists(pyfile):
        print(f"Error: File '{pyfile}' not found.")
        return

    # Compile the Python script
    try:
        py_compile.compile(pyfile, cfile=pyfile + 'c', doraise=True)
        print(f"Compilation successful. Output saved to {pyfile}c")
    except py_compile.PyCompileError as e:
        print(f"Compilation failed: {e}")

if __name__ == "__main__":
    compile_python_script()
