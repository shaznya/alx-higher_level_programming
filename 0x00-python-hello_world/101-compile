#!/usr/bin/python3
#!/bin/bash

# Check if the PYFILE environment variable is set
if [ -z "$PYFILE" ]; then
    echo "Error: PYFILE environment variable is not set."
    exit 1
fi

# Extract the file name and extension from the PYFILE
filename=$(basename -- "$PYFILE")
extension="${filename##*.}"
filename="${filename%.*}"

# Compile the Python script
python -m py_compile "$PYFILE"

# Check if the compilation was successful
if [ $? -eq 0 ]; then
    # Rename the compiled file
    mv "__pycache__/$filename.cpython-*.pyc" "$filename.pyc"
    echo "Compilation successful. Output filename: $filename.pyc"
else
    echo "Compilation failed."
fi

# Clean up temporary files
rm -rf __pycache__
